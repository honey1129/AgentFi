# Sepolia testnet deployment example.
DEPLOY_RPC_URL=https://sepolia.infura.io/v3/your-project-id
DEPLOY_PRIVATE_KEY=0xyour-deployer-private-key

CONTRACT_NAME=AgentOwnershipNFT
CONTRACT_SYMBOL=AGENT
NFT_CONTRACT_ADDRESS=

# Optional. Use a multisig or operator wallet after deployment if needed.
CONTRACT_OWNER=

# Optional. If omitted, deployer remains the runtime minter.
RUNTIME_MINTER_ADDRESS=

# Public URL where tokenURI metadata will be served from.
PUBLIC_BASE_URL=https://your-runtime-host.example.com
SOLC_VERSION=0.8.24
