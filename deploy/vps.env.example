APP_NAME=AgentFi Runtime
APP_DOMAIN=agentfi.example.com
CADDY_EMAIL=ops@example.com

API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/v1

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=agentfi
MYSQL_USER=agentfi
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

SCHEDULER_TICK_SECONDS=10

AGENT_EXECUTOR_MODE=openai_compatible
MODEL_BASE_URL=https://your-openai-compatible-endpoint
MODEL_API_KEY=CHANGE_ME_MODEL_API_KEY
MODEL_NAME=your-model-name

PUBLIC_BASE_URL=https://agentfi.example.com

WEB3_PROVIDER_URL=https://your-testnet-or-mainnet-rpc
NFT_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_NFT_CONTRACT
MARKETPLACE_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_MARKETPLACE_CONTRACT
NFT_MINTER_PRIVATE_KEY=CHANGE_ME_OR_LEAVE_EMPTY_IF_NOT_AUTO_MINTING

WEB3_START_BLOCK=
WEB3_POLL_INTERVAL_SECONDS=5
WEB3_BLOCK_BATCH_SIZE=1000
NFT_TX_TIMEOUT_SECONDS=120

AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_CHALLENGE_RATE_LIMIT=8
AUTH_VERIFY_RATE_LIMIT=8
MUTATION_RATE_LIMIT_WINDOW_SECONDS=60
MUTATION_RATE_LIMIT_PER_WALLET=30

RUN_DEFAULT_TIMEOUT_SECONDS=90
RUN_DEFAULT_MAX_ATTEMPTS=3
RUN_RETRY_BACKOFF_SECONDS=5
RUNTIME_LOG_DEFAULT_LIMIT=50
